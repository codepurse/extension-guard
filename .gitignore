# Go build output
/guard.exe
/guard
*.exe
/bin/
/dist/

# Generated Windows version-info resource (built from cmd/guard/versioninfo.json
# by goversioninfo during build.ps1); linked automatically by `go build`.
/cmd/guard/resource_windows.syso

# NOTE: /extension-ids.json at the repo root is the tracked source of truth
# (the multi-extension force-install config). The copies placed next to the
# binary live under release/ and release-linux/, which are ignored below.

# Throwaway test config (real Web Store ID for lock testing)
/test-ids.json

# Installer build output
/installer/output/

# Wails status UI build artifacts
/statusui/build/bin/
/statusui/frontend/node_modules/
/statusui/frontend/wailsjs/

# The frontend UI is hand-authored SOURCE (embedded via go:embed), not build
# output - keep it despite the repo-root "dist/" ignore rule.
!/statusui/frontend/dist/
!/statusui/frontend/dist/**

# Release output (built by build.ps1 / build-linux.sh)
/release/
/release-linux/
